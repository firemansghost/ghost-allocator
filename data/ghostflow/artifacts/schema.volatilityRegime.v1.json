{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghost-allocator.local/schemas/ghostflow-volatility-regime.v1.json",
  "title": "GhostFlow Volatility Regime artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactVersion",
    "signalId",
    "asOf",
    "source",
    "updateFrequency",
    "dataQuality",
    "observations"
  ],
  "properties": {
    "artifactVersion": {
      "type": "string",
      "const": "1"
    },
    "signalId": {
      "type": "string",
      "const": "vol-regime"
    },
    "asOf": {
      "type": "string",
      "format": "date"
    },
    "publishedAt": {
      "type": "string",
      "format": "date"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },
    "updateFrequency": {
      "type": "string",
      "enum": ["daily"]
    },
    "dataQuality": {
      "type": "string",
      "enum": ["verified_manual", "manual_unverified"]
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vixClose"],
      "properties": {
        "vixClose": { "type": "number", "minimum": 5, "maximum": 90 }
      }
    },
    "optionalObservations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vix9dClose": { "type": ["number", "null"], "minimum": 5, "maximum": 90 },
        "vix3mClose": { "type": ["number", "null"], "minimum": 5, "maximum": 90 },
        "spyRealizedVol21dAnn": { "type": ["number", "null"], "minimum": 0, "maximum": 200 }
      }
    }
  }
}
