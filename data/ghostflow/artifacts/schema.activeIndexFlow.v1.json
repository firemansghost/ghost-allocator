{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghost-allocator.local/schemas/ghostflow-active-index-flow.v1.json",
  "title": "GhostFlow Active vs Index Flow artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactVersion",
    "signalId",
    "asOf",
    "source",
    "seriesDefinition",
    "updateFrequency",
    "dataQuality",
    "observations"
  ],
  "properties": {
    "artifactVersion": {
      "type": "string",
      "const": "1"
    },
    "signalId": {
      "type": "string",
      "const": "active-index-flow"
    },
    "asOf": {
      "type": "string",
      "format": "date"
    },
    "publishedAt": {
      "type": "string",
      "format": "date"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },
    "seriesDefinition": {
      "type": "string",
      "const": "domestic_equity_active_index_monthly_net_flows"
    },
    "updateFrequency": {
      "type": "string",
      "const": "monthly"
    },
    "dataQuality": {
      "type": "string",
      "enum": ["verified_manual", "manual_unverified"]
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activeDomesticEquityNetFlowMillionsUsd",
        "indexDomesticEquityNetFlowMillionsUsd"
      ],
      "properties": {
        "activeDomesticEquityNetFlowMillionsUsd": {
          "type": "number",
          "minimum": -100000,
          "maximum": 150000
        },
        "indexDomesticEquityNetFlowMillionsUsd": {
          "type": "number",
          "minimum": -100000,
          "maximum": 150000
        }
      }
    },
    "optionalObservations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worldEquityActiveMillionsUsd": { "type": ["number", "null"] },
        "worldEquityIndexMillionsUsd": { "type": ["number", "null"] },
        "totalLongTermActiveMillionsUsd": { "type": ["number", "null"] },
        "totalLongTermIndexMillionsUsd": { "type": ["number", "null"] }
      }
    }
  }
}
