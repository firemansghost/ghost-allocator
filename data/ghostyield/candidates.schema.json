{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghost-allocator.local/schemas/ghostyield-candidates.json",
  "title": "GhostYield manual candidates",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "ticker",
      "name",
      "sleeveType",
      "yieldSource",
      "role",
      "sourceLabel",
      "dataAsOf",
      "updateFrequency",
      "dataConfidence",
      "distributionQuality",
      "mainRisks",
      "bestUseCase",
      "avoidIf",
      "currentYield"
    ],
    "properties": {
      "ticker": {
        "type": "string",
        "pattern": "^[A-Z]{1,8}$"
      },
      "name": { "type": "string", "minLength": 1 },
      "sleeveType": {
        "type": "string",
        "enum": [
          "cash_tbills",
          "credit_income",
          "preferred_income",
          "cef_credit",
          "opportunistic_credit",
          "special_situations_income",
          "bdc_income",
          "midstream_income",
          "natural_resources_income",
          "option_income",
          "crypto_yield_coming_soon"
        ]
      },
      "structureLabel": { "type": "string" },
      "yieldSource": { "type": "string", "minLength": 1 },
      "currentYield": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0, "maximum": 1 }
        ]
      },
      "secYield": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0, "maximum": 1 }
        ]
      },
      "navTrend1Y": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "navTrend3Y": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "premiumDiscount": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "leverage": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0, "maximum": 1.5 }
        ]
      },
      "expenseRatio": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0, "maximum": 1 }
        ]
      },
      "distributionQuality": {
        "type": "string",
        "enum": ["strong", "mixed", "weak", "uncertain"]
      },
      "role": { "type": "string", "minLength": 1 },
      "mainRisks": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "bestUseCase": { "type": "string", "minLength": 1 },
      "avoidIf": { "type": "string", "minLength": 1 },
      "dataAsOf": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "sourceLabel": { "type": "string", "minLength": 1 },
      "sourceUrl": {
        "anyOf": [{ "type": "null" }, { "type": "string" }]
      },
      "confidence": {
        "type": "string",
        "enum": ["high", "medium", "low", "illustrative"]
      },
      "dataConfidence": {
        "type": "string",
        "enum": ["high", "medium", "low", "illustrative"]
      },
      "marketPrice": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0 }
        ]
      },
      "nav": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0 }
        ]
      },
      "navPerformance1M": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "navPerformance3M": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "navPerformance1Y": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "navPerformance3Y": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "marketPerformance1M": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "marketPerformance3M": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "marketPerformance1Y": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "marketPerformance3Y": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "latestDistributionAmount": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0 }
        ]
      },
      "latestDistributionDate": {
        "anyOf": [
          { "type": "null" },
          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        ]
      },
      "distributionFrequency": {
        "type": "string",
        "enum": ["weekly", "monthly", "quarterly", "semiannual", "variable"]
      },
      "distributionRate": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0, "maximum": 1 }
        ]
      },
      "estimatedReturnOfCapitalPct": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": 0, "maximum": 1 }
        ]
      },
      "navYieldSpread": {
        "anyOf": [
          { "type": "null" },
          { "type": "number", "minimum": -1, "maximum": 1 }
        ]
      },
      "navDataAsOf": {
        "anyOf": [
          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          { "type": "null" }
        ]
      },
      "distributionDataAsOf": {
        "anyOf": [
          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          { "type": "null" }
        ]
      },
      "quarterlyFundamentalDataAsOf": {
        "anyOf": [
          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          { "type": "null" }
        ]
      },
      "updateFrequency": {
        "type": "string",
        "enum": ["daily", "weekly", "monthly", "quarterly", "manual"]
      }
    }
  }
}
